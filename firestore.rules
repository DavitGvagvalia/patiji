rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsInvitation(invitationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/invitations/$(invitationId))
        && get(/databases/$(database)/documents/invitations/$(invitationId)).data.ownerId == request.auth.uid;
    }

    function invitationIsActive(invitationId) {
      return exists(/databases/$(database)/documents/invitations/$(invitationId))
        && get(/databases/$(database)/documents/invitations/$(invitationId)).data.status == 'active';
    }

    function optionalString(fieldName, minSize, maxSize) {
      return !(fieldName in request.resource.data)
        || (
          request.resource.data[fieldName] is string
          && request.resource.data[fieldName].size() >= minSize
          && request.resource.data[fieldName].size() <= maxSize
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['displayName', 'email', 'createdAt', 'updatedAt'])
        && request.resource.data.email is string;
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt']);
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true;
      allow write: if false;
    }

    match /purchases/{purchaseId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /customInquiries/{inquiryId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'userId',
          'customerName',
          'customerEmail',
          'preferredContactMethod',
          'coupleNames',
          'weddingDate',
          'location',
          'guestCountRange',
          'requestedFeatures',
          'stylePreference',
          'palettePreference',
          'languageSupport',
          'budgetRange',
          'desiredLaunchDate',
          'notes',
          'status',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'userId',
          'customerName',
          'customerEmail',
          'preferredContactMethod',
          'coupleNames',
          'requestedFeatures',
          'languageSupport',
          'budgetRange',
          'status',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 1
        && request.resource.data.customerName.size() <= 120
        && request.resource.data.customerEmail is string
        && request.resource.data.customerEmail.size() >= 3
        && request.resource.data.customerEmail.size() <= 254
        && request.resource.data.preferredContactMethod in ['email', 'phone', 'whatsapp']
        && request.resource.data.coupleNames is string
        && request.resource.data.coupleNames.size() >= 1
        && request.resource.data.coupleNames.size() <= 160
        && request.resource.data.requestedFeatures is list
        && request.resource.data.requestedFeatures.size() >= 1
        && request.resource.data.requestedFeatures.size() <= 7
        && request.resource.data.requestedFeatures.hasOnly([
          'rsvp',
          'schedule',
          'venue-map',
          'gallery',
          'multilingual',
          'story',
          'registry'
        ])
        && request.resource.data.languageSupport is list
        && request.resource.data.languageSupport.size() >= 1
        && request.resource.data.languageSupport.size() <= 3
        && request.resource.data.languageSupport.hasOnly(['English', 'Georgian', 'Russian'])
        && request.resource.data.budgetRange in [
          '$500-$1,000',
          '$1,000-$2,500',
          '$2,500-$5,000',
          '$5,000+'
        ]
        && optionalString('weddingDate', 1, 10)
        && optionalString('location', 1, 160)
        && optionalString('guestCountRange', 1, 40)
        && optionalString('stylePreference', 1, 120)
        && optionalString('palettePreference', 1, 120)
        && optionalString('desiredLaunchDate', 1, 10)
        && optionalString('notes', 1, 1200)
        && request.resource.data.status == 'submitted'
        && request.resource.data.source == 'catalog-custom-website'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update, delete: if false;
    }

    match /publicInvitations/{slug} {
      allow read: if resource.data.status == 'active';
      allow write: if false;
    }

    match /invitations/{invitationId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if false;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'slug',
          'status',
          'coupleNames',
          'weddingDate',
          'updatedAt'
        ]);
      allow delete: if false;

      match /guestAnswers/{answerId} {
        allow read: if ownsInvitation(invitationId);
        allow create: if invitationIsActive(invitationId)
          && request.resource.data.keys().hasOnly([
          'guestName',
          'attending',
          'partySize',
          'message',
          'submittedAt'
        ])
          && request.resource.data.guestName is string
          && request.resource.data.guestName.size() >= 1
          && request.resource.data.guestName.size() <= 120
          && request.resource.data.attending is bool
          && request.resource.data.partySize is int
          && request.resource.data.partySize >= 1
          && request.resource.data.partySize <= 20
          && request.resource.data.submittedAt == request.time
          && (
            !('message' in request.resource.data)
            || (request.resource.data.message is string && request.resource.data.message.size() <= 500)
          );
        allow update, delete: if false;
      }
    }
  }
}
